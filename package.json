{
  "name": "olteststack",
  "version": "0.1.0",
  "description": "AI Browser Testing Framework — MCP server for Chromium automation",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r src/dashboard/public dist/dashboard/public",
    "dev": "bun run src/index.ts",
    "dev:http": "MCP_TRANSPORT=http HEALTH_PORT=8081 bun run src/index.ts",
    "dashboard": "HEALTH_PORT=8081 DASHBOARD_ENABLED=true bun run src/dashboard/serve.ts",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "smoke": "bun run scripts/smoke-test-mcp.ts",
    "test:mcp": "bun run scripts/test-mcp-tools.ts",
    "test:mcp:docker": "MCP_URL=http://localhost:8092/mcp bun run scripts/test-mcp-tools.ts",
    "docker:up": "docker compose up -d postgres",
    "docker:app": "docker compose --profile app up -d --build",
    "docker:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:cleanup": "bun run src/db/cleanup-expired.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "puppeteer": "^24.10.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
