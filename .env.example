# OLTestStack — development environment variables
# Copy to .env and adjust as needed.
# WARNING: Default credentials below are for local dev only. Change for production.

# --- PostgreSQL (Docker Compose) ---
# Host port 5433 maps to container 5432 (see docker-compose.yml)
POSTGRES_USER=oltest
POSTGRES_PASSWORD=oltest
POSTGRES_DB=olteststack
POSTGRES_HOST_PORT=5433

# Connection string for the app (host machine → Docker Postgres)
DATABASE_URL=postgresql://oltest:oltest@localhost:5433/olteststack

# When running app inside Docker Compose, use service hostname instead:
# DATABASE_URL=postgresql://oltest:oltest@postgres:5432/olteststack

# --- Recording persistence ---
# When DATABASE_URL is set, sessions persist on browser_close / test_run by default.
# Set PERSIST_RECORDING=false to opt out of writes while keeping DATABASE_URL for the dashboard.
PERSIST_RECORDING=

# Hours until unsaved (ephemeral) sessions are auto-deleted. Saved sessions never expire.
SESSION_TTL_HOURS=24

# When true, failed/error sessions are auto-promoted to saved (no TTL) on browser_close / test_run.
# Defaults to true when DATABASE_URL is set. Set AUTO_SAVE_FAILED=false to keep failed runs ephemeral.
AUTO_SAVE_FAILED=

# --- Optional HTTP health endpoint (Docker app service) ---
# HEALTH_PORT / MCP_HTTP_PORT = ports the app listens on inside the container (or local dev:http).
# APP_HOST_PORT / MCP_HOST_PORT = host ports Docker maps to the container (defaults avoid 8081/8082 conflicts with bun run dev:http).
HEALTH_PORT=8081
APP_HOST_PORT=8091

# Session dashboard (served at /dashboard on the health port)
DASHBOARD_ENABLED=true

# Hostname for fetchable screenshot URLs returned by page_screenshot (default localhost)
# SCREENSHOT_PUBLIC_HOST=localhost

# --- MCP transport ---
# stdio = local IDE spawns process (default, backward compatible)
# http  = Streamable HTTP for Docker / remote / multi-client
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8082
MCP_HOST_PORT=8092

# Docker app service overrides (set in docker-compose.yml):
# MCP_TRANSPORT=http
# MCP_HTTP_HOST=0.0.0.0

# --- Browser / MCP ---
BROWSER_HEADLESS=true
# CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
DEFAULT_TIMEOUT_MS=30000
DEFAULT_NAVIGATION_TIMEOUT_MS=30000
SCREENSHOT_DIR=./screenshots
# Server-local directory allowed for page_upload file paths
UPLOAD_DIR=./uploads
