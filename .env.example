# OLTestStack — development environment variables
# Copy to .env and adjust as needed.
# WARNING: Default credentials below are for local dev only. Change for production.

# --- PostgreSQL (Docker Compose) ---
# Host port 5433 maps to container 5432 (see docker-compose.yml)
POSTGRES_USER=oltest
POSTGRES_PASSWORD=oltest
POSTGRES_DB=olteststack
POSTGRES_HOST_PORT=5433

# Connection string for the app (host machine → Docker Postgres)
DATABASE_URL=postgresql://oltest:oltest@localhost:5433/olteststack

# When running app inside Docker Compose, use service hostname instead:
# DATABASE_URL=postgresql://oltest:oltest@postgres:5432/olteststack

# --- Recording persistence ---
# When true, recorded events and test reports are written to PostgreSQL on flush.
# Active browser/page sessions remain in-memory for MCP performance.
PERSIST_RECORDING=false

# --- Optional HTTP health endpoint (Docker app service) ---
HEALTH_PORT=8081
APP_HOST_PORT=8081

# --- MCP transport ---
# stdio = local IDE spawns process (default, backward compatible)
# http  = Streamable HTTP for Docker / remote / multi-client
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=8082
MCP_HOST_PORT=8082

# Docker app service overrides (set in docker-compose.yml):
# MCP_TRANSPORT=http
# MCP_HTTP_HOST=0.0.0.0

# --- Browser / MCP ---
BROWSER_HEADLESS=true
# CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser
DEFAULT_TIMEOUT_MS=30000
DEFAULT_NAVIGATION_TIMEOUT_MS=30000
SCREENSHOT_DIR=./screenshots
